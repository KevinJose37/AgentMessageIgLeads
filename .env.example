# ============================================
# IG Message Variation Service - Configuration
# ============================================

# --- Authentication ---
# API key required for all endpoints (generate a strong random string)
API_KEY=your-secret-api-key-here

# --- Ollama Configuration ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT=600

# --- Generation Settings ---
DEFAULT_NUM_VARIATIONS=20
MAX_VARIATIONS_PER_REQUEST=100
BATCH_SIZE=10
TEMPERATURE=0.8

# --- Cache ---
CACHE_ENABLED=true
CACHE_DB_PATH=data/cache.db
CACHE_TTL_HOURS=168

# --- App ---
DEBUG=false
